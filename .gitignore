# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# reference assets (photos / guides)
/reference/

# local Claude Code tooling
.claude/

# root-level fix/inject scripts (Claude Code artifacts)
fix_*.js
inject*.js
add_*.js
execute.js
extract_*.js
final_*.js
perfect_fix.js
recover_*.js
strip_and_link.js
